# Petfinder API (required — get keys at https://www.petfinder.com/developers/)
PETFINDER_API_KEY=
PETFINDER_SECRET=

# RescueGroups API (optional — public endpoints work without key)
RESCUE_GROUPS_API_KEY=

# Anthropic API (required)
ANTHROPIC_API_KEY=

# Server
PORT=3001
HOST=0.0.0.0
LOG_LEVEL=info
NODE_ENV=development

# CORS
CORS_ORIGIN=http://localhost:5173

# Database
DB_PATH=./data/pawpal.db

# Privacy (set to true to redact zip codes from logs)
REDACT_PII=false
